<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <Title>JugadoresXmlJam</Title>
    <Authors>$(AssemblyName),xewison,jugadores,futbol</Authors>
    <Description>Nuget que devuelve jugadores de un archivo xml</Description>
    <PackageIcon>kaneki.png</PackageIcon>
    <PackageTags>futbol;xewison;tajamar;futbol</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="jugadores.xml" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="jugadores.xml" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\..\..\Downloads\kaneki.png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

</Project>
